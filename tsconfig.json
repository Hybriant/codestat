{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleDetection": "force",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "bin/**/*.ts",
    "index.ts",
    "demo.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
